# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Large binary assets — serve from CDN, do not track in git
/public/assets/GULFO SOUND PRODUCTS/
/public/assets/*.jpg
/public/assets/*.jpeg
/public/assets/*.JPG
/public/assets/*.JPEG
/public/assets/plain/

# Keep MP4 originals out of git (too large)
*.mp4

# Booking data (contains customer PII — do not track in git)
/data/
